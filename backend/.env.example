APP_ENV=dev
APP_NAME=Interview Collector API
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:7357,http://localhost:7357,http://127.0.0.1:7360,http://localhost:7360

# AI provider config
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_MODEL=your_ark_endpoint_id
AI_API_KEY=replace_me
AI_TIMEOUT_SECONDS=120
AI_CONNECT_TIMEOUT_SECONDS=15
AI_READ_TIMEOUT_SECONDS=120
AI_RETRIES=2
AI_MAX_OUTPUT_TOKENS=3000
AI_DEBUG_RAW_RESPONSE=false
AI_THINKING_TYPE=disabled

# Import preview: cache AI extract per (prompt + chunk) to reduce duplicate billing
IMPORT_PREVIEW_CACHE_ENABLED=true
IMPORT_PREVIEW_CACHE_TTL_SECONDS=1800

# Daily practice: reuse recent grade if same question + same answer within window (no extra AI call)
PRACTICE_DAILY_IDEMPOTENCY_ENABLED=true
PRACTICE_DAILY_IDEMPOTENCY_SECONDS=60

# Database
DATABASE_URL=mysql+pymysql://root:456456@127.0.0.1:3306/interviewCollector?charset=utf8mb4

